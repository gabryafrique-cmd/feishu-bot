\
@app.route("/push", methods=["POST"])\
def push():\
    try:\
        # \uc0\u25509 \u25910 \u25105 \u21457 \u26469 \u30340 \u21608 \u25253 \u20869 \u23481 \
        data = request.get_json()\
        if not data or "content" not in data:\
            return \{"error": "\uc0\u32570 \u23569  content \u23383 \u27573 "\}, 400\
        \
        content = data["content"]\
        \
        # \uc0\u39134 \u20070 \u28040 \u24687 \u38480 \u21046  30000 \u23383 \u31526 \u65292 \u33258 \u21160 \u20998 \u27573 \
        max_len = 29000\
        parts = [content[i:i+max_len] for i in range(0, len(content), max_len)]\
        \
        results = []\
        for idx, part in enumerate(parts):\
            msg = f"\uc0\u12304 \u21608 \u25253 \u20998 \u27573  \{idx+1\}/\{len(parts)\}\u12305 \\n\{part\}" if len(parts) > 1 else part\
            payload = \{\
                "msg_type": "text",\
                "content": \{"text": msg\}\
            \}\
            resp = requests.post(WEBHOOK_URL, json=payload, timeout=10)\
            results.append(\{\
                "part": idx + 1,\
                "status": "success" if resp.status_code == 200 else "failed",\
                "code": resp.status_code\
            \})\
        \
        return \{"status": "ok", "results": results\}\
    except Exception as e:\
        return \{"error": str(e)\}, 500\
\
